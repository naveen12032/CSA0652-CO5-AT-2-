#include <stdio.h>
int set[20];
int subset[20];
int n;
void lexicographic(int start, int size)
{
    printf("{ ");
    for(int i=0;i<size;i++)
        printf("%d ",subset[i]);
    printf("}\n");

    for(int i=start;i<n;i++)
    {
        subset[size]=set[i];

        lexicographic(i+1,size+1);
    }
}
int main()
{
    printf("Enter number of elements: ");
    scanf("%d",&n);

    printf("Enter sorted elements:\n");

    for(int i=0;i<n;i++)
        scanf("%d",&set[i]);

    printf("Subsets in Lexicographic Order:\n");

    lexicographic(0,0);

    return 0;
}
