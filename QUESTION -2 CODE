#include <stdio.h>
int set[20];
int subset[20];
int n;
void generate(int index, int size)
{
    if(index==n)
    {
        printf("{ ");
        for(int i=0;i<size;i++)
            printf("%d ",subset[i]);
        printf("}\n");
        return;
    }
    subset[size]=set[index];
    generate(index+1,size+1);
    generate(index+1,size);
}
int main()
{
    printf("Enter number of elements: ");
    scanf("%d",&n);
    printf("Enter elements:\n");
    for(int i=0;i<n;i++)
        scanf("%d",&set[i]);
    printf("All Subsets:\n");
    generate(0,0);
    return 0;
}
